node_modules/
.env
.env.local
*.log
.DS_Store
dist/
venv/
*.pyc
__pycache__/
scripts/dashboard/logs/

# Per-workspace runtime state written by hooks; not a plugin deliverable.
.claude/metrics/

# Per-project host-local state written by setup hooks (v2.4.2+). Broad pattern
# covers YAML today; MD/JSON variants if adopted later.
.claude/*.local.*

# Repo-root .mcp.json is dev-personal only (v2.4.4+). Developer-personal MCP
# servers belong in user-scope ~/.claude/settings.json, not committed to the
# repo where consumers or casual readers might pick them up by accident.
/.mcp.json

# scripts/mcp-servers/ ships plugin-owned servers only (referenced by
# .claude-plugin/.mcp.json). Dev-personal MCPs belong in ~/.claude/mcp/.
# Allow-list — adding a new shipped MCP requires an explicit exception here.
scripts/mcp-servers/*
!scripts/mcp-servers/fs.js

{
  "$schema": "../schemas/install-modules.schema.json",
  "version": "1.0.0",
  "modules": [
    {
      "id": "agents-core",
      "kind": "agents",
      "description": "Core pipeline agents: Paige (lead), Artie (architect), Una (UX), Sam (security), Beck (backend), Effie (frontend), Quinn (QA)",
      "paths": [
        "agents/paige-product.md",
        "agents/artie-arch.md",
        "agents/una-ux.md",
        "agents/sam-sec.md",
        "agents/beck-backend.md",
        "agents/effie-frontend.md",
        "agents/quinn-qa.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-governance",
      "kind": "agents",
      "description": "Code reviewer: Stan Standards (logic + performance + language-specific quality, read-only)",
      "paths": [
        "agents/stan-standards.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-ship",
      "kind": "agents",
      "description": "Ship agent: Devon Ops (docs + changelog + release + announcement, ultimate trump card)",
      "paths": [
        "agents/devon-ops.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-utility",
      "kind": "agents",
      "description": "Utility agent: Heracles (debugger, root cause analysis, on-demand)",
      "paths": [
        "agents/heracles.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "skills-engineering",
      "kind": "skills",
      "description": "General engineering skills — useful standalone, outside the pipeline",
      "paths": [
        "skills/api-design/",
        "skills/c4-architecture/",
        "skills/code-review/",
        "skills/commit-work/",
        "skills/database-schema-designer/",
        "skills/datadog-cli/",
        "skills/design-system/",
        "skills/error-handling/",
        "skills/game-changing-features/",
        "skills/generate-fuzz-data/",
        "skills/git-workflow/",
        "skills/tdd-patterns/"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "skills-java",
      "kind": "skills",
      "description": "Java / Spring Boot skills — coding standards, patterns, TDD, security",
      "paths": [
        "skills/java-coding-standards/",
        "skills/springboot-patterns/",
        "skills/springboot-tdd/",
        "skills/springboot-security/"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "skills-pipeline",
      "kind": "skills",
      "description": "Pipeline artifact writers — define format/schema for review artifacts (SDD, CODE-REVIEW, REVIEW, UX-SPEC)",
      "paths": [
        "skills/write-code-review/",
        "skills/write-sdd/",
        "skills/write-security-review/",
        "skills/write-ux-spec/"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "skills-specialized",
      "kind": "skills",
      "description": "Specialized skills: task breakdown, project discovery, post-deploy analytics, QA planning, templates, entropy reduction, requirements clarity",
      "paths": [
        "skills/task-breakdown/",
        "skills/project-discovery/",
        "skills/post-deploy-analytics/",
        "skills/qa-test-planner/",
        "skills/readme-templates/",
        "skills/reducing-entropy/",
        "skills/requirements-clarity/"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "skills-superclaude",
      "kind": "skills",
      "description": "SuperClaude verb-skills inlined from SuperClaude_Plugin v4.3.0 (MIT). Full set of 13 verbs used by ohmyclaude agents: brainstorm, research, spec-panel, pm, estimate, design, analyze, implement, build, test, improve, troubleshoot, document. Ships with ohmyclaude — no external dependency on SuperClaude.",
      "paths": [
        "skills/sc-brainstorm/",
        "skills/sc-research/",
        "skills/sc-spec-panel/",
        "skills/sc-pm/",
        "skills/sc-estimate/",
        "skills/sc-design/",
        "skills/sc-analyze/",
        "skills/sc-implement/",
        "skills/sc-build/",
        "skills/sc-test/",
        "skills/sc-improve/",
        "skills/sc-troubleshoot/",
        "skills/sc-document/"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "rules-common",
      "kind": "rules",
      "description": "Common coding style rules — apply to all languages",
      "paths": [
        "rules/common/coding-style.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "rules-java",
      "kind": "rules",
      "description": "Java rules — coding style, patterns, security, testing (path-activated on **/*.java)",
      "paths": [
        "rules/java/coding-style.md",
        "rules/java/patterns.md",
        "rules/java/security.md",
        "rules/java/testing.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "commands",
      "kind": "commands",
      "description": "Single entry point: /forge (route, sprint, release, commit, help)",
      "paths": [
        "commands/forge.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "hooks-quality",
      "kind": "hooks",
      "description": "Quality hooks: block writes with secrets (PreToolUse), run linter after bash (PostToolUse)",
      "paths": [
        "hooks/hooks.json",
        "hooks/scripts/pre-write-check.js",
        "hooks/scripts/post-bash-lint.js"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "hooks-graph",
      "kind": "hooks",
      "description": "Source graph hook: incremental code-review-graph update after code changes (optional, skips if not installed)",
      "paths": [
        "hooks/scripts/graph-update.js"
      ],
      "targets": ["claude"],
      "defaultInstall": false,
      "stability": "stable"
    },
    {
      "id": "hooks-tracking",
      "kind": "hooks",
      "description": "Tracking hooks: backlog index rebuild, session summary, team cleanup",
      "paths": [
        "hooks/scripts/backlog-tracker.js",
        "hooks/scripts/session-summary.js",
        "hooks/scripts/team-cleanup.js"
      ],
      "targets": ["claude"],
      "defaultInstall": false,
      "stability": "stable"
    }
  ]
}

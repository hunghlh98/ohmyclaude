{
  "$schema": "../schemas/install-modules.schema.json",
  "version": "0.3.0",
  "modules": [
    {
      "id": "agents-strategy",
      "kind": "agents",
      "description": "Tier 1 — Strategy & Design: Paige Product (Grand Router), Artie Arch (C4 architect), Una UX (accessibility + UX spec), Scout Sprint (planner)",
      "paths": [
        "agents/paige-product.md",
        "agents/artie-arch.md",
        "agents/una-ux.md",
        "agents/scout-sprint.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-security",
      "kind": "agents",
      "description": "Tier 2 — Security: Sam Sec (security, compliance, adversarial plan validator)",
      "paths": [
        "agents/sam-sec.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-implementation",
      "kind": "agents",
      "description": "Tier 2 — Execution: Beck Backend (BE builder), Effie Frontend (FE builder), Heracles (debugger), Quinn QA (test writer)",
      "paths": [
        "agents/beck-backend.md",
        "agents/effie-frontend.md",
        "agents/heracles.md",
        "agents/quinn-qa.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-review",
      "kind": "agents",
      "description": "Tier 3 — Governance (read-only reviewers): Stan Standards (logic & conventions), Percy Perf (performance)",
      "paths": [
        "agents/stan-standards.md",
        "agents/percy-perf.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-docs",
      "kind": "agents",
      "description": "Tier 3 — Documentation: Dora Docs (README, API docs, Keep a Changelog)",
      "paths": [
        "agents/dora-docs.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-release",
      "kind": "agents",
      "description": "Tier 3 — SRE / DevOps: Devon Ops (release manager, ultimate trump card on production stability)",
      "paths": [
        "agents/devon-ops.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-community",
      "kind": "agents",
      "description": "Tier 4 — Post-Release: Evan Evangelist (DevRel/community), Anna Analytics (telemetry + feedback loop)",
      "paths": [
        "agents/evan-evangelist.md",
        "agents/anna-analytics.md"
      ],
      "targets": ["claude"],
      "defaultInstall": false,
      "stability": "stable"
    },
    {
      "id": "skills-core",
      "kind": "skills",
      "description": "Core engineering skills: git-workflow, tdd-patterns, api-design, error-handling, code-review",
      "paths": [
        "skills/git-workflow/",
        "skills/tdd-patterns/",
        "skills/api-design/",
        "skills/error-handling/",
        "skills/code-review/"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "commands-forge",
      "kind": "commands",
      "description": "Forge — single OSS entry point: /forge init, request, triage, sprint, release, analyze",
      "paths": [
        "commands/forge.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "commands-core",
      "kind": "commands",
      "description": "Developer utility commands: /review, /commit, /debug",
      "paths": [
        "commands/review.md",
        "commands/commit.md",
        "commands/debug.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "hooks-quality",
      "kind": "hooks",
      "description": "Quality hooks: block writes with secrets (PreToolUse), run linter after bash (PostToolUse)",
      "paths": [
        "hooks/hooks.json",
        "hooks/scripts/pre-write-check.js",
        "hooks/scripts/post-bash-lint.js"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "hooks-backlog",
      "kind": "hooks",
      "description": "Backlog tracker: auto-rebuilds BACKLOG.md index when ISS-*.md files are written",
      "paths": [
        "hooks/scripts/backlog-tracker.js"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "hooks-tracking",
      "kind": "hooks",
      "description": "Session tracking: write usage summary on Stop",
      "paths": [
        "hooks/scripts/session-summary.js"
      ],
      "targets": ["claude"],
      "defaultInstall": false,
      "stability": "stable"
    },
    {
      "id": "rules-core",
      "kind": "rules",
      "description": "Engineering standards: function size, naming, immutability, error handling, security baseline",
      "paths": [
        "rules/engineering-standards.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "contexts",
      "kind": "contexts",
      "description": "Session mode contexts: oss (full pipeline), dev, review, debug — loads the right agents and behavior for each working mode",
      "paths": [
        "contexts/oss.md",
        "contexts/dev.md",
        "contexts/review.md",
        "contexts/debug.md"
      ],
      "targets": ["claude"],
      "defaultInstall": true,
      "stability": "stable"
    },
    {
      "id": "agents-polyglot",
      "kind": "agents",
      "description": "Multi-language reviewer (Java, Kotlin, Go, Python, Rust, TypeScript, C++, Flutter, Database/SQL) and build error resolver for any language/build tool",
      "paths": [
        "agents/polyglot-reviewer.md",
        "agents/build-resolver.md"
      ],
      "targets": ["claude"],
      "defaultInstall": false,
      "stability": "stable"
    },
    {
      "id": "mcp-lsp",
      "kind": "mcp",
      "description": "LSP MCP server: goto-definition, find-references, symbols, diagnostics, rename",
      "paths": [
        "mcp/lsp-server/",
        ".mcp.json"
      ],
      "targets": ["claude"],
      "defaultInstall": false,
      "dependencies": ["node >= 18"],
      "stability": "experimental"
    }
  ]
}

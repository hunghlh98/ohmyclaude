{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-write-check.js\"",
            "timeout": 5
          }
        ],
        "description": "Block writes that contain hardcoded secrets (API keys, passwords, tokens)"
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/val-calibration.js\"",
            "timeout": 3
          }
        ],
        "description": "Inject calibration-examples.md anchor into val-evaluator Task prompts (calibration-read enforcement)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-bash-lint.js\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Run project linter after bash commands that modify source files"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/cost-profiler.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Aggregate /forge run telemetry → PROFILE-{runId}.md and baseline.json"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/cost-profiler.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Snapshot cumulative transcript totals per subagent for cost profiling"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/project-init.js\"",
            "async": false,
            "timeout": 5
          }
        ],
        "description": "Bootstrap ohmyclaude scaffolding on first launch in a git repo root (.claude/ohmyclaude/.initialised sentinel + .claude/{usage,backlog/issues}/, BACKLOG.md, CLAUDE.md if missing). Idempotent; silent no-op when guardrails fail or sentinel exists."
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/code-review-graph-setup.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Detect `uv` prereq for code-review-graph MCP; write <cwd>/.claude/ohmyclaude.local.yaml with setup status on first run (self-gates on .mcp.json declaration)"
      }
    ]
  }
}

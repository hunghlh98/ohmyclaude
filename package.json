{
  "name": "ohmyclaude",
  "version": "3.0.1",
  "description": "11-agent OSS pipeline for Claude Code — generator/evaluator separation (Anthropic Labs harness paper), sprint contract gate, single /forge entry point, Agent Teams coordination, Java-first skills.",
  "author": "ohmyclaude contributors",
  "license": "MIT",
  "homepage": "https://github.com/hunghlh98/ohmyclaude",
  "repository": {
    "type": "git",
    "url": "https://github.com/hunghlh98/ohmyclaude.git"
  },
  "keywords": [
    "claude-code",
    "multi-agent",
    "orchestration",
    "skills",
    "hooks",
    "lsp",
    "quality"
  ],
  "files": [
    "agents/",
    "skills/",
    "commands/",
    "hooks/",
    "rules/",
    "manifests/",
    "schemas/",
    "scripts/",
    "docs/",
    ".claude-plugin/",
    ".mcp.json",
    "VERSION",
    "README.md",
    "ROADMAP.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "validate": "node scripts/validate.js",
    "version:bump": "node scripts/bump-version.js",
    "test:sc-fallback": "node scripts/test-sc-fallback.js",
    "test:hooks": "node scripts/test-hooks.js",
    "test:agents": "node scripts/test-agents.js",
    "test:probe": "node scripts/test-probe.js",
    "usage-report": "node scripts/usage-report.js",
    "dashboard": "python3 scripts/dashboard/server.py",
    "prepublishOnly": "node scripts/validate.js && node scripts/test-hooks.js && node scripts/test-agents.js && node scripts/test-probe.js"
  },
  "engines": {
    "node": ">=18"
  }
}

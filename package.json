{
  "name": "ohmyclaude",
  "version": "0.3.0",
  "description": "14-agent OSS company simulation pipeline for Claude Code — document-driven, dynamically routed, with conflict resolution and post-release feedback loop.",
  "author": "ohmyclaude contributors",
  "license": "MIT",
  "homepage": "https://github.com/hunghlh98/ohmyclaude",
  "repository": {
    "type": "git",
    "url": "https://github.com/hunghlh98/ohmyclaude.git"
  },
  "keywords": [
    "claude-code",
    "multi-agent",
    "orchestration",
    "skills",
    "hooks",
    "lsp",
    "quality"
  ],
  "bin": {
    "ohmyclaude": "./scripts/ohmyclaude.js"
  },
  "files": [
    "agents/",
    "skills/",
    "commands/",
    "hooks/",
    "rules/",
    "mcp/",
    "contexts/",
    "manifests/",
    "schemas/",
